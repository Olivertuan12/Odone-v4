rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Phase 2: Validation Blueprints
    function isValidProject(data) {
      return data.keys().hasAll(['ownerId', 'title', 'client', 'status', 'dueDate', 'progress', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 8 &&
             data.ownerId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.client is string && data.client.size() <= 200 &&
             data.status in ['pending', 'progress', 'review', 'delivered', 'error'] &&
             data.dueDate is string && data.dueDate.size() <= 50 &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['ownerId', 'timestamp', 'text', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.ownerId == request.auth.uid &&
             data.timestamp is string && data.timestamp.size() <= 50 &&
             data.text is string && data.text.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    // Collections
    match /projects/{projectId} {
      // Allow read if user is owner
      allow get: if isSignedIn() && isValidId(projectId) && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && existing().ownerId == request.auth.uid;

      allow create: if isSignedIn() && 
                    isValidId(projectId) && 
                    isValidProject(incoming()) && 
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;

      allow update: if isSignedIn() && 
                    isValidId(projectId) && 
                    existing().ownerId == request.auth.uid &&
                    isValidProject(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'client', 'status', 'dueDate', 'progress', 'updatedAt'])
                    );

      allow delete: if isSignedIn() && isValidId(projectId) && existing().ownerId == request.auth.uid;

      match /comments/{commentId} {
        // Read if user is owner of the parent project. We use get() on the parent.
        allow get: if isSignedIn() && isValidId(projectId) && isValidId(commentId) &&
                   get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
        allow list: if isSignedIn() && isValidId(projectId) &&
                   get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;

        // Note: For create, user must own the valid project
        allow create: if isSignedIn() && isValidId(projectId) && isValidId(commentId) &&
                      get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid &&
                      isValidComment(incoming()) &&
                      incoming().createdAt == request.time;
        
        // No update for comments
        allow update: if false;
        
        allow delete: if isSignedIn() && isValidId(projectId) && isValidId(commentId) && 
                      existing().ownerId == request.auth.uid;
      }
    }
  }
}
